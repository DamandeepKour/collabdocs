# =============================================================================
# CollabDocs — Environment Variables
# Copy to `.env` and fill in values. Never commit `.env`.
# =============================================================================

# --- App ---
NODE_ENV=development

# --- Database (Neon PostgreSQL or local Postgres) ---
# Prisma 7 reads this via prisma.config.ts
DATABASE_URL=DATABASE_URL="postgresql://damandeep:Dkour%4031@localhost:5432/collabdocs"

# --- Auth.js / NextAuth v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth providers (optional — enable in Phase 2)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- AI provider abstraction ---
# Switch providers with a single variable: openai | gemini | groq
# Default: Groq free tier (same pattern as FitNova)
AI_PROVIDER="groq"
AI_MODEL="llama-3.3-70b-versatile"
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
GROQ_API_KEY=""

# --- Realtime (Phase 6) ---
NEXT_PUBLIC_WS_URL="http://localhost:3000"

# --- Security / limits ---
MAX_PAYLOAD_BYTES=1048576
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
