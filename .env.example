# =============================================================================
# CollabDocs — Environment Variables
# Copy to `.env` and fill in values. Never commit `.env`.
# =============================================================================

NODE_ENV=development

# --- Database (Neon / Render / local Postgres) ---
# Local:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/collabdocs?schema=public"
# Render/Neon (use External URL + SSL):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Auth.js / NextAuth v5 ---
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- AI (Groq free tier recommended) ---
AI_PROVIDER="groq"
AI_MODEL="llama-3.3-70b-versatile"
GROQ_API_KEY=""
OPENAI_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- Author footer (submission requirement) ---
NEXT_PUBLIC_AUTHOR_NAME="Damandeep Kour"
NEXT_PUBLIC_GITHUB_URL="https://github.com/DamandeepKour/"
NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/in/damandeep-kour-104264251/"
NEXT_PUBLIC_AUTHOR_EMAIL="daman1901319@gmail.com"

# --- Limits ---
MAX_PAYLOAD_BYTES=1048576
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
