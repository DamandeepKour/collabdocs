// =============================================================================
// Prisma Schema — Local-First Collaborative Document Editor
// Phase 1: Skeleton schema. Full auth & relations expanded in Phase 2.
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum DocumentRole {
  OWNER
  EDITOR
  VIEWER
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CONFLICT
}

enum AiProvider {
  OPENAI
  GEMINI
  GROQ
}

enum AiFeature {
  SUMMARIZE
  REWRITE
  GRAMMAR
  CONTINUE
  BULLETS
  MEETING_NOTES
  TITLE
  SMART_TAGS
  CHAT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SHARE
  RESTORE
  SYNC
  AI_REQUEST
  LOGIN
  LOGOUT
}

// -----------------------------------------------------------------------------
// Auth.js (NextAuth v5) models — wired in Phase 2
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// Credentials auth (Phase 2). Null when OAuth-only.
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  documents     Document[]       @relation("DocumentOwner")
  permissions   Permission[]
  versions      DocumentVersion[]
  syncQueue     SyncQueueItem[]
  auditLogs     AuditLog[]
  aiRequests    AiRequest[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------------
// Documents
// -----------------------------------------------------------------------------

model Document {
  id          String   @id @default(cuid())
  title       String   @default("Untitled")
  content     Json     @default("{}")
  /// Monotonic server version for conflict detection
  version     Int      @default(1)
  /// Content hash for integrity checks
  contentHash String?
  tags        String[] @default([])
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  permissions Permission[]
  versions    DocumentVersion[]
  syncQueue   SyncQueueItem[]
  aiRequests  AiRequest[]
  auditLogs   AuditLog[]

  @@index([ownerId])
  @@index([updatedAt])
  @@map("documents")
}

model Permission {
  id         String       @id @default(cuid())
  role       DocumentRole @default(VIEWER)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([userId])
  @@map("permissions")
}

// -----------------------------------------------------------------------------
// Version history
// -----------------------------------------------------------------------------

model DocumentVersion {
  id          String   @id @default(cuid())
  version     Int
  title       String
  content     Json
  contentHash String?
  label       String?
  createdAt   DateTime @default(now())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId, createdAt])
  @@map("document_versions")
}

// -----------------------------------------------------------------------------
// Sync engine queue (server-side tracking)
// -----------------------------------------------------------------------------

model SyncQueueItem {
  id          String     @id @default(cuid())
  clientId    String
  operation   String
  payload     Json
  status      SyncStatus @default(PENDING)
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  lastError   String?    @db.Text
  nextRetryAt DateTime?
  baseVersion Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([documentId, userId])
  @@index([clientId])
  @@map("sync_queue")
}

// -----------------------------------------------------------------------------
// AI usage / audit
// -----------------------------------------------------------------------------

model AiRequest {
  id        String     @id @default(cuid())
  provider  AiProvider
  feature   AiFeature
  model     String?
  promptTokens Int?
  completionTokens Int?
  latencyMs Int?
  success   Boolean    @default(true)
  error     String?    @db.Text
  metadata  Json?
  createdAt DateTime   @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([documentId])
  @@map("ai_requests")
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([documentId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
